# # .github/workflows/build-ami-scheduled.yml
# # =============================================================================
# # Scheduled trigger for AMI builds
# #
# # Rebuilds ALL templates marked schedule: true in template-registry.json
# # on the 1st of every month at 6 AM UTC.
# #
# # Uses OIDC for AWS authentication — no stored credentials.
# #
# # NOTE: GitHub disables scheduled workflows on repos with no commit activity
# # for 60 days. Push periodically or use repository_dispatch from an external
# # scheduler instead.
# # =============================================================================

# name: "Build AMIs (Monthly)"

